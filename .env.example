# ─── ALPACA ───────────────────────────────────────────────────
# Paper trading (test mode)
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_KEY=your_paper_api_key
ALPACA_SECRET=your_paper_api_secret

# Live trading — swap these in when ready to go live
# ALPACA_BASE_URL=https://api.alpaca.markets
# ALPACA_KEY=your_live_api_key
# ALPACA_SECRET=your_live_api_secret

# ─── MARKET DATA ──────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key
FINNHUB_API_KEY=your_finnhub_api_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# ─── DATABASE ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=stocktrader
DB_PASSWORD=your_db_password
DB_NAME=stocktrader

# ─── EMAIL NOTIFICATIONS ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
NOTIFY_EMAIL=your@gmail.com

# ─── APP ──────────────────────────────────────────────────────
PORT=3000
APP_URL=http://192.168.1.156:3000
NODE_ENV=development

# ─── RISK PARAMETERS ──────────────────────────────────────────
ACCOUNT_SIZE=10000
MAX_POSITION_PCT=0.10        # Max 10% of account per trade
STOP_LOSS_PCT=0.05           # 5% stop loss on every position
MAX_OPEN_POSITIONS=4         # Max simultaneous open positions
MAX_DAILY_TRADES=4           # Max new trades per day
MIN_SCORE_THRESHOLD=65       # Min score to show as candidate
MIN_PROBABILITY=60           # Min probability % to show candidate
